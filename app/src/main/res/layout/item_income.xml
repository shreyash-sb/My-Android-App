<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardIncome"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/color_surface"
    app:cardCornerRadius="18dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/frameIncomeBadge"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_badge_success"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvIncomeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/color_success"
                android:textSize="18sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvIncomeReason"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/color_text_primary"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@id/tvIncomeAmount"
            app:layout_constraintStart_toEndOf="@id/frameIncomeBadge"
            app:layout_constraintTop_toTopOf="@id/frameIncomeBadge" />

        <TextView
            android:id="@+id/tvIncomeDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:fontFamily="sans-serif"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/tvIncomeAmount"
            app:layout_constraintStart_toStartOf="@id/tvIncomeReason"
            app:layout_constraintTop_toBottomOf="@id/tvIncomeReason" />

        <TextView
            android:id="@+id/tvIncomeAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/color_success"
            android:textSize="17sp"
            app:layout_constraintBottom_toBottomOf="@id/frameIncomeBadge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/frameIncomeBadge" />

        <View
            android:id="@+id/accentBar"
            android:layout_width="3dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_accent_bar"
            app:layout_constraintBottom_toBottomOf="@id/frameIncomeBadge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/frameIncomeBadge" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
