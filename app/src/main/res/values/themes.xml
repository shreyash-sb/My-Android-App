<resources>
    <style name="Theme.SmartExpenseTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryContainer">@color/color_primary_dark</item>
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorSecondaryContainer">@color/color_secondary_soft</item>
        <item name="colorTertiary">@color/color_tertiary</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorSurfaceVariant">@color/color_surface_alt</item>
        <item name="colorOutline">@color/color_stroke</item>
        <item name="android:windowBackground">@color/color_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/color_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="materialButtonStyle">@style/Widget.SmartExpenseTracker.Button</item>
        <item name="materialCardViewStyle">@style/Widget.SmartExpenseTracker.Card</item>
        <item name="toolbarStyle">@style/Widget.SmartExpenseTracker.Toolbar</item>
        <item name="textInputStyle">@style/Widget.SmartExpenseTracker.TextInputLayout</item>
    </style>

    <style name="Widget.SmartExpenseTracker.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_large</item>
        <item name="strokeColor">@color/color_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardUseCompatPadding">false</item>
    </style>

    <style name="Widget.SmartExpenseTracker.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_medium</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.SmartExpenseTracker.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextColor">@color/color_text_primary</item>
        <item name="subtitleTextColor">@color/color_text_secondary</item>
    </style>

    <style name="Widget.SmartExpenseTracker.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_medium</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_medium</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_medium</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_medium</item>
        <item name="boxStrokeColor">@color/color_stroke</item>
        <item name="hintTextColor">@color/color_text_secondary</item>
    </style>
</resources>
