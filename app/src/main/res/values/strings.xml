    <string name="about_intro_title">Why this app</string>
    <string name="about_intro_body">Smart Expense Tracker is built for fast daily entries, budget planning, analytics, and clean report export without unnecessary complexity.</string>
    <string name="about_security_title">Security and privacy</string>
    <string name="about_security_body">Email and password sign-in is handled by Firebase Authentication. Expense, income, and budget data are stored in Firestore and protected by per-user security rules. Report PDFs are generated locally in app cache only when you export them.</string>
    <string name="about_data_title">What is stored</string>
    <string name="about_data_body">The app stores your profile details, expenses, income entries, and monthly budgets. It does not require Google sign-in, Firebase Storage, or paid Firebase features for the current setup.</string>
